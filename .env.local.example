# ─── Siro Véd – Email konfiguráció ───────────────────────────────────────────
# Másold le ezt a fájlt .env.local névre és töltsd ki a valós adatokkal.

# Admin email – ide érkeznek az ajánlatkérések
SIROVED_ADMIN_EMAIL=info@siroved.hu

# SMTP beállítások (pl. Gmail, Hostinger, Zoho stb.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false          # true = SSL/465, false = STARTTLS/587
SMTP_USER=info@siroved.hu
SMTP_PASS=your-password-or-app-password
